//LinkedList Operations
import java.util.LinkedList;
   public class LinkedListExample{
     public static void main(String[] args){
     //Create a LinkedList
     LinkedList<String> colors = new LinkedList<>();

     //Add elemets to the LinkedList
     colors.add("Red");
     colors.add("Green");
     colors.add("Blue");
     //Access an element
     System.out.println("First color: " + colors.get(0)); //Output: First color: Red
     //Remove an element
     colors.remove("Green");
     //Print all elements
     System.out.println("Colors list: " + colors);
    }
}
     
