//Inner classes in java
class OuterClass{
 int outerVariable = 10;
 class InnerClass{
   void display(){
     System.out.println("Outer variable value : " + outerVariable);
   }
 }
}

public class Main {
 public static void main(String[] args){
   OuterClass outer = new OuterClass(); //Create an instance of Outerclass
   OuterClass.InnerClass inner = outer.new InnerClass();Create an instance of Innerclass
   inner.display(); //Call the display method
  }
}
