//No arg Constructor
class Car{
 String Model;
 int year;
 Car(){
   model = "Default Model";
   year = 2025;//default year
 }
 void display(){
    System.out.println("Car Model: "+model + ", Year: " + year);
 }
}
public class Main {
  public static void main(String[] args){
    Car myCar = new Car();//no-arg constructor
    myCar.display();//Output : Car Model : default Model,Year : 2020
 }
} 
